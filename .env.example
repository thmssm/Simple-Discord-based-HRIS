# HRIS Dashboard — Environment Variables
# Copy to .env and fill in your values.

# Discord Bot Token (required for bot.py)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# LLM API Key for AI features (absence parsing, summaries, etc.)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Cloudflare Turnstile (optional — for login CAPTCHA protection)
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# HRIS Database Path (default: hr.db in current directory)
HRBOT_DB_PATH=hr.db

# HRIS Log Path (default: bot.log in current directory)
HRBOT_LOG_PATH=bot.log

# Service name for watchdog (default: hr-bot.service)
HRBOT_SERVICE=hr-bot.service

# Discord Channel IDs for attendance tracking (comma-separated)
ABSENSI_CHANNEL_ID=0
